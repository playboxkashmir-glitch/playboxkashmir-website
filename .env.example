# Copy this file's contents into Vercel Project Settings -> Environment Variables.
# Never commit a real .env file with actual secrets to git.

# PostgreSQL connection string (Vercel Postgres, Neon, Supabase, Railway, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Long random secret used to sign admin session tokens (JWT).
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# SMTP credentials used to send booking confirmation emails.
# Works with Gmail, Zoho, SendGrid, Mailgun, Amazon SES SMTP, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=PlayBox Kashmir <you@example.com>

# Used only when running scripts/create-admin.mjs locally to seed the first admin user.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password
